{
	"info": {
		"_postman_id": "inventory-management-system",
		"name": "Inventory Management System",
		"description": "Complete API collection for Authentication and Inventory Management System",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register Admin",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@1234\",\n  \"role\": \"ADMIN\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						},
						"description": "Register a new ADMIN user"
					},
					"response": [
						{
							"name": "Success",
							"status": "Created",
							"code": 201,
							"body": ""
						}
					]
				},
				{
					"name": "Register Staff",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"staff@example.com\",\n  \"password\": \"Staff@1234\",\n  \"role\": \"STAFF\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						},
						"description": "Register a new STAFF user"
					},
					"response": [
						{
							"name": "Success",
							"status": "Created",
							"code": 201,
							"body": ""
						}
					]
				},
				{
					"name": "Login Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token saved:', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@1234\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Login as ADMIN - token is automatically saved to collection variable"
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiJ9...\"\n}"
						}
					]
				},
				{
					"name": "Login Staff",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.token) {",
									"    pm.collectionVariables.set('token', jsonData.token);",
									"    console.log('Token saved:', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"staff@example.com\",\n  \"password\": \"Staff@1234\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "login"]
						},
						"description": "Login as STAFF - token is automatically saved to collection variable"
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiJ9...\"\n}"
						}
					]
				}
			]
		},
		{
			"name": "Inventory",
			"item": [
				{
					"name": "Create Item",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Laptop\",\n  \"quantity\": 10\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/items",
							"host": ["{{baseUrl}}"],
							"path": ["inventory", "items"]
						},
						"description": "Create a new inventory item - ADMIN only"
					},
					"response": [
						{
							"name": "Success",
							"status": "Created",
							"code": 201,
							"body": "{\n  \"id\": 1,\n  \"name\": \"Laptop\",\n  \"quantity\": 10\n}"
						}
					]
				},
				{
					"name": "Get All Items",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/inventory/items?page=0&size=10",
							"host": ["{{baseUrl}}"],
							"path": ["inventory", "items"],
							"query": [
								{
									"key": "page",
									"value": "0"
								},
								{
									"key": "size",
									"value": "10"
								}
							]
						},
						"description": "Get all inventory items with pagination - ADMIN and STAFF"
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"content\": [\n    {\n      \"id\": 1,\n      \"name\": \"Laptop\",\n      \"quantity\": 10\n    }\n  ],\n  \"totalElements\": 1,\n  \"totalPages\": 1,\n  \"size\": 10,\n  \"number\": 0\n}"
						}
					]
				},
				{
					"name": "Stock In",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"quantity\": 5\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/items/1/stock-in",
							"host": ["{{baseUrl}}"],
							"path": ["inventory", "items", "1", "stock-in"]
						},
						"description": "Add stock to item - ADMIN only"
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"id\": 1,\n  \"name\": \"Laptop\",\n  \"quantity\": 15\n}"
						}
					]
				},
				{
					"name": "Stock Out",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"quantity\": 3\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/items/1/stock-out",
							"host": ["{{baseUrl}}"],
							"path": ["inventory", "items", "1", "stock-out"]
						},
						"description": "Remove stock from item - ADMIN only"
					},
					"response": [
						{
							"name": "Success",
							"status": "OK",
							"code": 200,
							"body": "{\n  \"id\": 1,\n  \"name\": \"Laptop\",\n  \"quantity\": 12\n}"
						}
					]
				}
			]
		},
		{
			"name": "Validation Tests",
			"item": [
				{
					"name": "Register - Invalid Email",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"invalid-email\",\n  \"password\": \"Admin@1234\",\n  \"role\": \"ADMIN\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						},
						"description": "Should return 400 Bad Request - invalid email"
					},
					"response": [
						{
							"name": "Validation Error",
							"status": "Bad Request",
							"code": 400,
							"body": "{\n  \"email\": \"Invalid email format\"\n}"
						}
					]
				},
				{
					"name": "Register - Weak Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"weak\",\n  \"role\": \"ADMIN\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["auth", "register"]
						},
						"description": "Should return 400 Bad Request - weak password"
					},
					"response": [
						{
							"name": "Validation Error",
							"status": "Bad Request",
							"code": 400,
							"body": "{\n  \"password\": \"Password must be min 8 chars with uppercase, number, and special character\"\n}"
						}
					]
				},
				{
					"name": "Stock Out - Insufficient Stock",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"quantity\": 99999\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/items/1/stock-out",
							"host": ["{{baseUrl}}"],
							"path": ["inventory", "items", "1", "stock-out"]
						},
						"description": "Should return 400 Bad Request - insufficient stock"
					},
					"response": [
						{
							"name": "Error",
							"status": "Bad Request",
							"code": 400,
							"body": "{\n  \"error\": \"Insufficient stock. Available: 10\"\n}"
						}
					]
				},
				{
					"name": "Stock In - Invalid Item ID",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"quantity\": 5\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/items/999/stock-in",
							"host": ["{{baseUrl}}"],
							"path": ["inventory", "items", "999", "stock-in"]
						},
						"description": "Should return 404 Not Found - item does not exist"
					},
					"response": [
						{
							"name": "Not Found",
							"status": "Not Found",
							"code": 404,
							"body": "{\n  \"error\": \"Item not found with id: 999\"\n}"
						}
					]
				},
				{
					"name": "Create Item - STAFF Forbidden",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Monitor\",\n  \"quantity\": 5\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/inventory/items",
							"host": ["{{baseUrl}}"],
							"path": ["inventory", "items"]
						},
						"description": "Login as STAFF first then send - should return 403 Forbidden"
					},
					"response": [
						{
							"name": "Forbidden",
							"status": "Forbidden",
							"code": 403,
							"body": ""
						}
					]
				}
			]
		}
	]
}
